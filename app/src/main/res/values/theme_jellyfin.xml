<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Jellyfin" parent="@style/Theme.AppCompat.NoActionBar">
        <!-- Colors -->
        <item name="android:colorPrimary">@color/grey</item>
        <item name="android:colorPrimaryDark">@color/grey</item>
        <item name="android:colorAccent">@color/jellyfin_blue</item>
        <!-- Background resource or color -->
        <item name="android:windowBackground">@color/ds_background</item>
        <item name="defaultBackground">@color/ds_background</item>
        <!-- Default (non-active) button color -->
        <item name="android:colorButtonNormal">@color/grey</item>
        <item name="buttonDefaultNormalBackground">@color/button_default_normal_background</item>
        <item name="buttonDefaultHighlightBackground">@color/button_default_highlight_background</item>
        <!-- Default popup menu -->
        <item name="popupMenuBackground">@color/popup_menu_background</item>
        <!-- Progress Bar -->
        <item name="progressBackground">@color/grey_transparent</item>
        <item name="progressPrimary">@color/jellyfin_blue</item>
        <item name="progressSecondary">@color/jellyfin_purple</item>

        <!-- Custom Styles for Elements -->
        <item name="android:datePickerStyle">@style/DatePickerCustom</item>
        <item name="android:popupMenuStyle">@style/PopupMenu</item>
        <item name="android:popupWindowStyle">@style/PopupWindow</item>

        <!-- Rounding Values -->
        <item name="cardRounding">4dp</item>
        <item name="buttonRounding">10dp</item>
        <item name="inputRounding">10dp</item>
        <item name="popupMenuRounding">10dp</item>

        <!-- Dim level of non-focus grid items -->
        <item name="overlayDimDimmedLevel">30%</item>

        <!-- Control icons -->
        <item name="controlIconBackground">@color/button_default_normal_background</item>
        <item name="controlIconForegroundActive">@color/jellyfin_blue</item>
        <item name="controlIconForegroundInactive">@color/button_default_highlight_background</item>

        <!-- QR drawables -->
        <item name="qrBackground">@color/white</item>
        <item name="qrForeground">@color/black</item>

        <!-- Tile colors -->
        <item name="tile_port_person_bg">@color/indigo_dye</item>
        <item name="tile_port_video_bg">@color/indigo_dye</item>
        <item name="tile_land_folder_bg">@color/indigo_dye</item>
        <item name="tile_chapter_bg">@color/indigo_dye</item>
        <item name="tile_land_tv_bg">@color/indigo_dye</item>
        <item name="tile_port_tv_bg">@color/indigo_dye</item>
        <item name="tile_actors_bg">@color/indigo_dye</item>
        <item name="tile_land_photo_bg">@color/indigo_dye</item>
        <item name="tile_port_folder_bg">@color/indigo_dye</item>
        <item name="tile_land_series_timer_bg">@color/indigo_dye</item>

        <item name="tile_audio_bg">@color/midnight_blue</item>
        <item name="tile_artists_bg">@color/spanish_blue</item>
        <item name="tile_genres_bg">@color/midnight_blue</item>
        <item name="tile_search_bg">@color/spanish_blue</item>

        <item name="tile_suggestions_bg">@color/spanish_blue</item>
        <item name="tile_port_grid_bg">@color/midnight_blue</item>
        <item name="tile_letters_bg">@color/spanish_blue</item>

        <item name="tile_port_guide_bg">@color/spanish_blue</item>
        <item name="tile_port_series_timer_bg">@color/midnight_blue</item>
        <item name="tile_port_time_bg">@color/spanish_blue</item>

        <item name="android:dialogTheme">@style/Theme.Jellyfin.Dialog</item>
    </style>

    <style name="Theme.Jellyfin.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ds_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/vegafox_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Jellyfin</item>
    </style>

    <style name="Theme.Jellyfin.Dialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
