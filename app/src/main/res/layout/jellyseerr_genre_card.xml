<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/genre_card"
    android:layout_width="300dp"
    android:layout_height="150dp"
    android:layout_margin="@dimen/ds_space_xs"
    app:cardCornerRadius="@dimen/ds_radius_sm"
    app:cardElevation="@dimen/ds_elevation_md">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/genre_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:id="@+id/genre_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/jellyseerr_genre_overlay"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/genre_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="@dimen/ds_space_12"
                android:shadowColor="@color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:textAppearance="@style/TextAppearance.DS.TitleSmall"
                android:textColor="@color/ds_text_primary"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
