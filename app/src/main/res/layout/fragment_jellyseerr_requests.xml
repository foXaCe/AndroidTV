<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/black">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical"
		android:padding="@dimen/ds_space_md">

		<!-- Header -->
		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/jellyseerr_my_requests"
			android:textSize="@dimen/ds_text_headline_md"
			android:textStyle="bold"
			android:textColor="@color/ds_text_primary"
			android:layout_marginBottom="@dimen/ds_space_md" />

		<!-- Connection Status Warning -->
		<LinearLayout
			android:id="@+id/not_connected_warning"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="@dimen/ds_space_md"
			android:background="@color/red"
			android:layout_marginBottom="@dimen/ds_space_md"
			android:visibility="gone">

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_not_connected"
				android:textSize="@dimen/ds_text_body_lg"
				android:textStyle="bold"
				android:textColor="@color/ds_text_primary" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_go_to_settings"
				android:textSize="@dimen/ds_text_body_md"
				android:textColor="@color/ds_text_secondary"
				android:layout_marginTop="@dimen/ds_space_sm" />

		</LinearLayout>

		<!-- Loading State -->
		<LinearLayout
			android:id="@+id/loading_state"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical"
			android:gravity="center"
			android:visibility="gone">

			<ProgressBar
				android:layout_width="64dp"
				android:layout_height="64dp"
				android:layout_marginBottom="@dimen/ds_space_md"
				android:indeterminateTint="@color/ds_secondary_dark" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_loading_requests"
				android:textSize="@dimen/ds_text_body_lg"
				android:textColor="@color/ds_text_primary"
				android:gravity="center" />

		</LinearLayout>

		<!-- Requests List -->
		<FrameLayout
			android:layout_width="match_parent"
			android:layout_height="0dp"
			android:layout_weight="1">

			<!-- Empty State -->
			<LinearLayout
				android:id="@+id/empty_state"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical"
				android:gravity="center"
				android:visibility="gone">

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/jellyseerr_no_requests"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="@color/ds_text_primary"
					android:gravity="center"
					android:layout_marginBottom="@dimen/ds_space_sm" />

				<TextView
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="@string/jellyseerr_submit_from_discover"
					android:textSize="@dimen/ds_text_body_md"
					android:textColor="@color/ds_text_secondary"
					android:gravity="center" />

			</LinearLayout>

			<!-- Requests RecyclerView -->
			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/requests_list"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:clipToPadding="false" />

		</FrameLayout>

		<!-- Refresh Button -->
		<Button
			android:id="@+id/refresh_button"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/btn_refresh"
			android:layout_gravity="center_horizontal"
			android:layout_marginTop="20dp" />

	</LinearLayout>

</FrameLayout>
