<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="wrap_content"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:padding="@dimen/ds_space_sm"
	android:background="?attr/selectableItemBackground">

	<!-- Title at top -->
	<TextView
		android:id="@+id/title_text"
		android:layout_width="160dp"
		android:layout_height="wrap_content"
		android:textSize="@dimen/ds_text_body_md"
		android:textStyle="bold"
		android:textColor="@color/ds_text_primary"
		android:maxLines="2"
		android:ellipsize="end"
		android:layout_marginBottom="@dimen/ds_space_xs"
		tools:text="The Matrix" />

	<FrameLayout
		android:layout_width="160dp"
		android:layout_height="240dp"
		android:layout_marginBottom="@dimen/ds_space_sm">

		<!-- Type Badge -->
		<TextView
			android:id="@+id/type_text"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="top|start"
			android:text="@string/lbl_movie_type_upper"
			android:textSize="@dimen/ds_text_label_sm"
			android:textStyle="bold"
			android:textColor="@color/ds_text_primary"
			android:paddingStart="6dp"
			android:paddingEnd="6dp"
			android:paddingTop="@dimen/ds_space_xs"
			android:paddingBottom="@dimen/ds_space_xs"
			android:background="@color/red"
			android:layout_margin="@dimen/ds_space_sm" />

		<!-- Rating Badge -->
		<LinearLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_gravity="bottom|end"
			android:orientation="horizontal"
			android:gravity="center"
			android:background="@color/ds_background"
			android:layout_margin="@dimen/ds_space_sm"
			android:paddingStart="6dp"
			android:paddingEnd="6dp"
			android:paddingTop="3dp"
			android:paddingBottom="3dp">

			<TextView
				android:id="@+id/rating_text"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="@dimen/ds_text_label_sm"
				android:textColor="@color/ds_text_primary"
				tools:text="7.5" />

		</LinearLayout>

	</FrameLayout>

	<!-- Description -->
	<TextView
		android:id="@+id/description_text"
		android:layout_width="160dp"
		android:layout_height="wrap_content"
		android:textSize="@dimen/ds_text_body_sm"
		android:textColor="@color/ds_text_primary"
		android:alpha="0.8"
		android:maxLines="3"
		android:ellipsize="end"
		tools:text="When a beautiful stranger leads computer hacker Neo to a forbidding underworld..." />

</LinearLayout>
