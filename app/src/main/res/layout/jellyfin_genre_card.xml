<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/genre_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/ds_radius_sm"
    app:cardElevation="@dimen/ds_elevation_md"
    android:foreground="?android:attr/selectableItemBackground"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Backdrop Image -->
        <ImageView
            android:id="@+id/genre_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/ds_surface_dim" />

        <!-- Gradient Overlay for text readability -->
        <View
            android:id="@+id/genre_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/genre_card_overlay" />

        <!-- Genre Title centered -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/ds_space_md">

            <TextView
                android:id="@+id/genre_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end"
                android:textAppearance="@style/TextAppearance.DS.TitleSmall"
                android:textColor="@color/ds_text_primary"
                android:textStyle="bold"
                android:shadowColor="@color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />

            <!-- Optional item count -->
            <TextView
                android:id="@+id/genre_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ds_space_xs"
                android:gravity="center"
                android:textAppearance="@style/TextAppearance.DS.BodySmall"
                android:textColor="@color/ds_text_secondary"
                android:shadowColor="@color/black"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:visibility="gone" />

        </LinearLayout>

    </FrameLayout>

</androidx.cardview.widget.CardView>
