<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/black">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="@dimen/ds_space_md">

		<!-- Header -->
		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/jellyseerr_settings"
			android:textSize="@dimen/ds_text_headline_md"
			android:textStyle="bold"
			android:textColor="@color/ds_text_primary"
			android:layout_marginBottom="@dimen/ds_space_sm" />

		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/jellyseerr_settings_description"
			android:textSize="@dimen/ds_text_body_md"
			android:textColor="@color/ds_text_secondary"
			android:layout_marginBottom="@dimen/ds_space_md" />

		<!-- Enable/Disable Toggle -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical"
			android:layout_marginBottom="@dimen/ds_space_md">

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/jellyseerr_enabled"
				android:textSize="@dimen/ds_text_body_lg"
				android:textColor="@color/ds_text_primary" />

			<androidx.appcompat.widget.SwitchCompat
				android:id="@+id/enabled_switch"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:checked="false" />

		</LinearLayout>

		<!-- Settings Group (can be disabled) -->
		<LinearLayout
			android:id="@+id/settings_group"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical">

			<!-- Server URL Input -->
			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_server_url"
				android:textSize="@dimen/ds_text_body_md"
				android:textStyle="bold"
				android:textColor="@color/ds_text_primary"
				android:layout_marginBottom="6dp" />

			<EditText
				android:id="@+id/server_url_input"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="@string/jellyseerr_server_url_description"
				android:inputType="textUri"
				android:textColorHint="@color/ds_text_secondary"
				android:textColor="@color/ds_text_primary"
				android:backgroundTint="@color/jellyfin_blue"
				android:padding="12dp"
				android:layout_marginBottom="@dimen/ds_space_md" />

			<!-- Connect with Jellyfin Button -->
			<Button
				android:id="@+id/connect_jellyfin_button"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_connect_jellyfin"
				android:textAllCaps="false"
				android:backgroundTint="@color/jellyfin_blue"
				android:layout_marginBottom="@dimen/ds_space_md" />

			<!-- Connection Status -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:gravity="center_vertical"
				android:layout_marginBottom="@dimen/ds_space_md"
				android:padding="@dimen/ds_space_sm"
				android:background="@color/grey">

				<ImageView
					android:id="@+id/status_icon"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:layout_marginEnd="12dp"
					android:contentDescription="@string/cd_connection_status" />

				<TextView
					android:id="@+id/status_text"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/jellyseerr_not_tested"
					android:textSize="@dimen/ds_text_body_md"
					android:textColor="@color/ds_text_primary" />

			</LinearLayout>

			<!-- Buttons -->
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:layout_marginBottom="12dp">

				<Button
					android:id="@+id/test_connection_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/jellyseerr_test_connection"
					android:textAllCaps="false"
					android:layout_marginEnd="6dp" />

				<Button
					android:id="@+id/save_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/btn_save"
					android:textAllCaps="false"
					android:layout_marginStart="6dp" />

			</LinearLayout>

		</LinearLayout>

		<!-- Fetch Limit Setting -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:layout_marginBottom="@dimen/ds_space_md">

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_fetch_limit_title"
				android:textSize="@dimen/ds_text_body_lg"
				android:textStyle="bold"
				android:textColor="@color/ds_text_primary"
				android:layout_marginBottom="6dp" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_fetch_limit_description"
				android:textSize="@dimen/ds_text_body_sm"
				android:textColor="@color/ds_text_secondary"
				android:layout_marginBottom="@dimen/ds_space_sm" />

			<Spinner
				android:id="@+id/fetch_limit_spinner"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="12dp"
				android:backgroundTint="@color/jellyfin_blue" />

		</LinearLayout>

		<!-- Info Section -->
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:layout_marginTop="@dimen/ds_space_xl"
			android:padding="@dimen/ds_space_sm"
			android:background="@color/grey">

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_setup_title"
				android:textSize="@dimen/ds_text_body_md"
				android:textStyle="bold"
				android:textColor="@color/ds_text_primary"
				android:layout_marginBottom="@dimen/ds_space_sm" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/jellyseerr_setup_info"
				android:textSize="@dimen/ds_text_body_sm"
				android:textColor="@color/ds_text_secondary"
				android:lineSpacingExtra="@dimen/ds_space_xs" />

		</LinearLayout>

	</LinearLayout>

</ScrollView>
